{% extends 'base.html.twig' %}

{% block title %}Gestion des tâches{% endblock %}

{% block body %}
    {% set nbAFaire = 0 %}
    {% set nbEnCours = 0 %}
    {% set nbTerminee = 0 %}
    {% for t in taches %}
        {% if t.statut == 'a_faire' %}
            {% set nbAFaire = nbAFaire + 1 %}
        {% elseif t.statut == 'en_cours' %}
            {% set nbEnCours = nbEnCours + 1 %}
        {% elseif t.statut == 'terminee' %}
            {% set nbTerminee = nbTerminee + 1 %}
        {% endif %}
    {% endfor %}

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0"><i class="bi bi-kanban"></i> Gestion des tâches</h1>
        <a href="{{ path('app_tache_new') }}" class="btn btn-primary">
            <i class="bi bi-plus-lg"></i> Nouvelle tâche
        </a>
    </div>

    <!-- Cartes de statistiques -->
    <div class="row mb-4 g-3">
        <div class="col-md-3">
            <div class="card p-3">
                <div class="text-muted small">Total</div>
                <div class="h3 mb-0">{{ taches|length }}</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card p-3 border-start border-4 border-secondary">
                <div class="text-muted small">À faire</div>
                <div class="h3 mb-0">{{ nbAFaire }}</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card p-3 border-start border-4 border-info">
                <div class="text-muted small">En cours</div>
                <div class="h3 mb-0">{{ nbEnCours }}</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card p-3 border-start border-4 border-success">
                <div class="text-muted small">Terminées</div>
                <div class="h3 mb-0">{{ nbTerminee }}</div>
            </div>
        </div>
    </div>

    <!-- Filtres -->
    <div class="btn-group mb-3" role="group">
        <a href="{{ path('app_tache_mes_taches') }}" class="btn btn-outline-primary">
            <i class="bi bi-person-check"></i> Mes tâches
        </a>
        <a href="{{ path('app_tache_index') }}" class="btn btn-outline-secondary">
            <i class="bi bi-list-ul"></i> Toutes les tâches
        </a>
    </div>

    <!-- Tableau -->
    <div class="card">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Titre</th>
                        <th>Description</th>
                        <th>Créée le</th>
                        <th>Échéance</th>
                        <th>Priorité</th>
                        <th>Statut</th>
                        <th>Assigné à</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for tache in taches %}
                    <tr>
                        <td class="text-muted">{{ tache.id }}</td>
                        <td class="fw-semibold">{{ tache.titre }}</td>
                        <td class="text-muted" style="max-width: 250px;">
                            {{ tache.description|length > 60 ? tache.description|slice(0, 60) ~ '...' : tache.description }}
                        </td>
                        <td>{{ tache.dataCreation ? tache.dataCreation|date('d/m/Y') : '' }}</td>
                        <td>{{ tache.dataEcheance ? tache.dataEcheance|date('d/m/Y') : '—' }}</td>
                        <td>
                            <span class="badge rounded-pill bg-{{ tache.priorite == 'urgente' ? 'dark' : (tache.priorite == 'haute' ? 'danger' : (tache.priorite == 'moyenne' ? 'warning text-dark' : 'secondary')) }}">
                                {{ tache.priorite }}
                            </span>
                        </td>
                        <td>
                            <span class="badge rounded-pill bg-{{ tache.statut == 'terminee' ? 'success' : (tache.statut == 'en_cours' ? 'info text-dark' : 'secondary') }}">
                                {{ tache.statut|replace({'_': ' '}) }}
                            </span>
                        </td>
                        <td>
                            {% if tache.assigneA %}
                                <i class="bi bi-person-fill text-primary"></i> {{ tache.assigneA.email }}
                            {% else %}
                                <span class="text-muted fst-italic">Non assignée</span>
                            {% endif %}
                        </td>
                        <td class="text-end">
                            <div class="dropdown">
                                <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown">
                                    Actions
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li><a class="dropdown-item" href="{{ path('app_tache_show', {'id': tache.id}) }}"><i class="bi bi-eye"></i> Voir</a></li>
                                    <li><a class="dropdown-item" href="{{ path('app_tache_edit', {'id': tache.id}) }}"><i class="bi bi-pencil"></i> Modifier</a></li>
                                    <li><a class="dropdown-item" href="{{ path('app_tache_assigner_moi', {'id': tache.id}) }}"><i class="bi bi-person-plus"></i> M'assigner</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item" href="{{ path('app_tache_changer_statut', {'id': tache.id, 'nouveauStatut': 'a_faire'}) }}">À faire</a></li>
                                    <li><a class="dropdown-item" href="{{ path('app_tache_changer_statut', {'id': tache.id, 'nouveauStatut': 'en_cours'}) }}">En cours</a></li>
                                    <li><a class="dropdown-item" href="{{ path('app_tache_changer_statut', {'id': tache.id, 'nouveauStatut': 'terminee'}) }}">Terminée</a></li>
                                    {% if is_granted('ROLE_ADMIN') %}
                                        <li><hr class="dropdown-divider"></li>
                                        <li>
                                            <form method="post" action="{{ path('app_tache_delete', {'id': tache.id}) }}" onsubmit="return confirm('Supprimer cette tâche ?');">
                                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ tache.id) }}">
                                                <button class="dropdown-item text-danger"><i class="bi bi-trash"></i> Supprimer</button>
                                            </form>
                                        </li>
                                    {% endif %}
                                </ul>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="9" class="text-center py-4 text-muted">
                            <i class="bi bi-inbox display-6 d-block mb-2"></i>
                            Aucune tâche trouvée.
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}